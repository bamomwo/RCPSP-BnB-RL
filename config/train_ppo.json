{
  "root": "data/train/1kNetRes",
  "pattern": "*.rcp",
  "max_instances": null,
  "max_resources": 4,
  "dominance": "set_based",

  "bc_checkpoint": "models/policy_bc.pt",
  "d_model": 64,
  "n_heads": 4,
  "n_layers": 2,
  "ffn_dim": 128,
  "dropout": 0.0,

  "total_env_steps": 5000000,
  "rollout_horizon": 1024,
  "ppo_epochs": 4,
  "minibatches": 4,
  "clip_eps": 0.2,
  "gamma": 0.99,
  "gae_lambda": 0.95,
  "ent_coef": 0.01,
  "vf_coef": 0.5,
  "lr": 3e-4,
  "max_grad_norm": 0.5,
  "target_kl": 0.02,
  "time_limit_s": 120.0,

  "step_cost": 0.01,
  "inc_coeff": 1.0,
  "gap_coeff": 2.0,
  "stuck_penalty": 0.05,
  "stuck_k": 150,
  "exhausted_per_activity": 1.0,

  "eval_every_steps": 100000,
  "eval_root": "data/eval/j30/j30_10",
  "eval_pattern": "*.RCP",
  "eval_time_limit_s": 60.0,
  "eval_optimal_json": "data/baseline/j30_opt.json",

  "save_path": "models/5m_nr/policy_ppo.pt",
  "checkpoint_dir": "models/5m_nr/checkpoints",
  "seed": 42,
  "device": "cpu"
}
